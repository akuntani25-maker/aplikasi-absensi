{
  "name": "aplikasi-absensi",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "patch-package",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "dev:mobile": "turbo run dev --filter=mobile",
    "dev:web": "turbo run dev --filter=web",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "patch-package": "^8.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@expo/ngrok": "^4.1.3",
    "ajv": "^8.18.0",
    "react-native-worklets": "npm:react-native-worklets-core@^1.6.3"
  }
}

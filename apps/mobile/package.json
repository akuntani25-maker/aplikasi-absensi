{
  "name": "mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "expo export",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "jest --watchAll=false",
    "test:unit": "jest --config jest.unit.config.js --watchAll=false",
    "clean": "rm -rf .expo dist node_modules"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@react-native-community/netinfo": "^11.4.1",
    "@shopify/flash-list": "1.7.3",
    "@supabase/supabase-js": "^2.47.2",
    "@tanstack/react-query": "^5.62.16",
    "ajv": "^8.18.0",
    "expo": "~53.0.0",
    "expo-build-properties": "^0.13.3",
    "expo-constants": "~17.0.0",
    "expo-dev-client": "~5.2.4",
    "expo-image": "~2.0.0",
    "expo-linking": "~7.0.0",
    "expo-local-authentication": "~15.0.0",
    "expo-location": "~18.0.0",
    "expo-router": "~4.0.0",
    "expo-secure-store": "~14.0.0",
    "expo-status-bar": "~2.2.0",
    "nativewind": "^4.1.23",
    "react": "19.0.0",
    "react-hook-form": "^7.54.2",
    "react-native": "0.79.6",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-mmkv": "^3.1.0",
    "react-native-reanimated": "~3.16.0",
    "react-native-safe-area-context": "4.14.0",
    "react-native-screens": "~4.9.0",
    "react-native-vision-camera": "^4.7.3",
    "react-native-vision-camera-face-detector": "^1.10.2",
    "react-native-worklets-core": "^1.6.3",
    "tailwindcss": "^3.4.17",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@testing-library/react-native": "^12.8.1",
    "@types/react": "~19.0.0",
    "@types/react-native": "~0.73.0",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~8.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^29.7.0",
    "jest-expo": "~53.0.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@shopify/flash-list|nativewind|react-native-reanimated)"
    ]
  }
}
